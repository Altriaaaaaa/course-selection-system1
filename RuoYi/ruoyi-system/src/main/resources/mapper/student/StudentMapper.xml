<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StudentMapper">

    <resultMap type="Student" id="StudentResult">
        <id     property="sno"          column="sno"          />
        <result property="sname"        column="sname"        />
        <result property="sex"          column="sex"          />
        <result property="birth"        column="birth"        />
        <result property="nativePlace"  column="native_place" />
        <result property="phone"        column="phone"        />
        <result property="passwordHash" column="password_hash"/>
        <result property="status"       column="status"       />
        <result property="deptId"       column="dept_id"      />
        <result property="createdBy"    column="created_by"   />
        <result property="deptName"     column="dept_name"    />
    </resultMap>

    <sql id="selectStudentVo">
        select s.sno, s.sname, s.sex, s.birth, s.native_place, s.phone,
               s.password_hash, s.status, s.dept_id, s.created_by,
               d.dept_name
        from student s
        left join department d on s.dept_id = d.dept_id
    </sql>

    <select id="selectStudentList" parameterType="Student" resultMap="StudentResult">
        <include refid="selectStudentVo"/>
        <where>
            <if test="sno != null and sno != ''">
                and s.sno like concat('%', #{sno}, '%')
            </if>
            <if test="sname != null and sname != ''">
                and s.sname like concat('%', #{sname}, '%')
            </if>
            <if test="deptId != null">
                and s.dept_id = #{deptId}
            </if>
        </where>
        order by s.sno
    </select>

    <select id="selectStudentById" parameterType="String" resultMap="StudentResult">
        <include refid="selectStudentVo"/>
        where s.sno = #{sno}
    </select>

    <select id="checkSnoUnique" parameterType="String" resultMap="StudentResult">
        select sno from student where sno = #{sno} limit 1
    </select>

    <insert id="insertStudent" parameterType="Student">
        insert into student(sno, sname, sex, birth, native_place, phone, password_hash, status, dept_id, created_by)
        values (#{sno}, #{sname}, #{sex}, #{birth}, #{nativePlace}, #{phone}, #{passwordHash}, #{status}, #{deptId}, #{createdBy})
    </insert>

    <update id="updateStudent" parameterType="Student">
        update student
        <set>
            <if test="sname != null and sname != ''">sname = #{sname},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="birth != null">birth = #{birth},</if>
            <if test="nativePlace != null">native_place = #{nativePlace},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="passwordHash != null and passwordHash != ''">password_hash = #{passwordHash},</if>
            <if test="status != null">status = #{status},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
        </set>
        where sno = #{sno}
    </update>

    <delete id="deleteStudentById" parameterType="String">
        delete from student where sno = #{sno}
    </delete>

</mapper>
