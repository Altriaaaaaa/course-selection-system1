<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CourseMapper">

    <resultMap type="Course" id="CourseResult">
        <id     property="cno"        column="cno"        />
        <result property="cname"      column="cname"      />
        <result property="credit"     column="credit"     />
        <result property="hours"      column="hours"      />
        <result property="courseType" column="course_type"/>
        <result property="deptId"     column="dept_id"    />
        <result property="adminId"    column="admin_id"   />
        <result property="deptName"   column="dept_name"  />
    </resultMap>

    <sql id="selectCourseVo">
        select c.cno, c.cname, c.credit, c.hours, c.course_type, c.dept_id, c.admin_id, d.dept_name
        from course c left join department d on c.dept_id = d.dept_id
    </sql>

    <select id="selectCourseList" parameterType="Course" resultMap="CourseResult">
        <include refid="selectCourseVo"/>
        <where>
            <if test="cno != null and cno != ''">
                and c.cno like concat('%', #{cno}, '%')
            </if>
            <if test="cname != null and cname != ''">
                and c.cname like concat('%', #{cname}, '%')
            </if>
            <if test="deptId != null and deptId != 0">
                and c.dept_id = #{deptId}
            </if>
        </where>
        order by c.cno
    </select>

    <select id="selectCourseById" parameterType="String" resultMap="CourseResult">
        <include refid="selectCourseVo"/>
        where c.cno = #{cno}
    </select>

    <select id="checkCnoUnique" parameterType="String" resultMap="CourseResult">
        <include refid="selectCourseVo"/>
        where c.cno = #{cno} limit 1
    </select>

    <select id="checkCnameUnique" parameterType="String" resultMap="CourseResult">
        <include refid="selectCourseVo"/>
        where c.cname = #{cname} limit 1
    </select>

    <insert id="insertCourse" parameterType="Course">
        insert into course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cno != null and cno != ''">cno,</if>
            <if test="cname != null and cname != ''">cname,</if>
            <if test="credit != null">credit,</if>
            <if test="hours != null">hours,</if>
            <if test="courseType != null">course_type,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="adminId != null and adminId != ''">admin_id,</if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cno != null and cno != ''">#{cno},</if>
            <if test="cname != null and cname != ''">#{cname},</if>
            <if test="credit != null">#{credit},</if>
            <if test="hours != null">#{hours},</if>
            <if test="courseType != null">#{courseType},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="adminId != null and adminId != ''">#{adminId},</if>
        </trim>
    </insert>

    <update id="updateCourse" parameterType="Course">
        update course
        <set>
            <if test="cname != null and cname != ''">cname = #{cname},</if>
            <if test="credit != null">credit = #{credit},</if>
            <if test="hours != null">hours = #{hours},</if>
            <if test="courseType != null">course_type = #{courseType},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
        </set>
        where cno = #{cno}
    </update>

    <delete id="deleteCourseById" parameterType="String">
        delete from course where cno = #{cno}
    </delete>

</mapper>
